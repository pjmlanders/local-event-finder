{
  "buildCommand": "npm run build --workspace=shared && npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
