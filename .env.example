# Server
PORT=3002
CLIENT_URL=https://your-app.vercel.app

# Affiliate IDs (optional) — earn fees on click-throughs
# Join: Ticketmaster https://developer.ticketmaster.com/partners/distribution-partners/affiliate-sign-up/
#       SeatGeek via Impact (seatgeek.com partner program)
#       Eventbrite via Awin (awin.com)
# TICKETMASTER_AFFILIATE_ID=your_affiliate_id
# SEATGEEK_AFFILIATE_ID=your_affiliate_id
# EVENTBRITE_AFFILIATE_ID=your_affiliate_id
# Click-throughs are logged always; persisted to Supabase (affiliate_clicks) when SUPABASE_URL/SUPABASE_SERVICE_KEY are set.
# GET /api/events/analytics/clicks returns counts by source for revenue reporting.
DATABASE_URL=postgresql://user:pass@host:5432/local_event_finder
TICKETMASTER_API_KEY=your_ticketmaster_api_key
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
SEATGEEK_CLIENT_SECRET=your_seatgeek_secret
# StubHub — email affiliates@stubhub.com to request partner API access
# STUBHUB_CLIENT_ID=your_stubhub_client_id
# STUBHUB_CLIENT_SECRET=your_stubhub_client_secret
# STUBHUB_AFFILIATE_ID=your_stubhub_affiliate_id
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# Client (VITE_ prefix required for Vite to expose to browser; dev uses Vite proxy, set for production)
VITE_API_BASE_URL=http://localhost:3002/api
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
